CREATE OR REPLACE PROCEDURE pr_sync_all_averages()
LANGUAGE plpgsql
AS $$
BEGIN
    UPDATE movie m SET average_grade = (SELECT AVG(grade) FROM grades WHERE id_movie = m.id_movie);
    
    UPDATE app_user u SET average_given_grade = (SELECT AVG(grade) FROM grades WHERE id_user = u.id_user);
    
    UPDATE crew_member c SET average_movies_grade = (
        SELECT AVG(m.average_grade)
        FROM movie m
        WHERE m.id_movie IN (
            SELECT id_movie FROM acts WHERE id_crew_member = c.id_crew_member
            UNION
            SELECT id_movie FROM directs WHERE id_crew_member = c.id_crew_member
        )
    );
END;
$$;

CREATE OR REPLACE FUNCTION fn_update_crew_average()
RETURNS TRIGGER AS $$
BEGIN
    UPDATE crew_member
    SET average_movies_grade = (
        SELECT AVG(m.average_grade)
        FROM movie m
        WHERE m.id_movie IN (
            SELECT id_movie FROM acts WHERE id_crew_member = COALESCE(NEW.id_crew_member, OLD.id_crew_member)
            UNION
            SELECT id_movie FROM directs WHERE id_crew_member = COALESCE(NEW.id_crew_member, OLD.id_crew_member)
        )
    )
    WHERE id_crew_member = COALESCE(NEW.id_crew_member, OLD.id_crew_member);

    RETURN NULL;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER trg_update_crew_member_acts
AFTER INSERT OR UPDATE OR DELETE ON acts
FOR EACH ROW
EXECUTE FUNCTION fn_update_crew_average();

CREATE TRIGGER trg_update_crew_member_directs
AFTER INSERT OR UPDATE OR DELETE ON directs
FOR EACH ROW
EXECUTE FUNCTION fn_update_crew_average();

