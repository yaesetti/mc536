CREATE OR REPLACE FUNCTION fn_update_averages()
RETURNS TRIGGER AS $$
BEGIN
    UPDATE movie
    SET average_grade = (
        SELECT AVG(grade)
        FROM grades
        WHERE id_movie = COALESCE(NEW.id_movie, OLD.id_movie)
    )
    WHERE id_movie = COALESCE(NEW.id_movie, OLD.id_movie);

    UPDATE app_user
    SET average_given_grade = (
        SELECT AVG(grade) 
        FROM grades
        WHERE id_user = COALESCE(NEW.id_user, OLD.id_user)
    )
    WHERE id_user = COALESCE(NEW.id_user, OLD.id_user);

    UPDATE crew_member
    SET average_movies_grade = (
        SELECT AVG(m.average_grade)
        FROM movie m
        WHERE m.id_movie IN (
            SELECT id_movie FROM acts WHERE id_crew_member = crew_member.id_crew_member
            UNION
            SELECT id_movie FROM directs WHERE id_crew_member = crew_member.id_crew_member
        )
    )
    WHERE id_crew_member IN (
        SELECT id_crew_member FROM acts WHERE id_movie = COALESCE(NEW.id_movie, OLD.id_movie)
        UNION
        SELECT id_crew_member FROM directs WHERE id_movie = COALESCE(NEW.id_movie, OLD.id_movie)
    );

    RETURN COALESCE(NEW, OLD);
END;
$$ LANGUAGE plpgsql;

DROP TRIGGER IF EXISTS trg_update_averages_grades ON grades;
CREATE TRIGGER trg_update_grades_changes
AFTER INSERT OR UPDATE OR DELETE ON grades
FOR EACH ROW
EXECUTE FUNCTION fn_update_averages();

ALTER TABLE grades
DROP CONSTRAINT IF EXISTS grades_id_user_fkey;
ALTER TABLE grades
ADD CONSTRAINT grades_id_user_fkey
FOREIGN KEY (id_user)
REFERENCES app_user(id_user)
ON DELETE CASCADE;